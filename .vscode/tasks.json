{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Pipeline Environment",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/.setup/setup.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}/.setup"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Initialize workspace, clone accelerators, and upload build framework to z/OS USS"
        },
        {
            "label": "Run Pipeline Simulation",
            "type": "shell",
            "command": "zowe",
            "args": [
                "rse-api-for-zowe-cli",
                "issue",
                "ssh",
                "\"bash ${input:pipelineScriptPath}\""
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "detail": "Execute the pipeline simulation script on z/OS USS via Zowe CLI"
        }
    ],
    "inputs": [
        {
            "id": "pipelineScriptPath",
            "type": "promptString",
            "description": "Path to pipeline simulation script on USS",
            "default": "/u/${env:USER}/sandbox/pipeline_simulation.sh"
        }
    ]
}